{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/stop_quality_reminder.py",
            "timeout": 10,
            "statusMessage": "Checking pending rule candidates"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/pre_bash_release_guard.py",
            "timeout": 10,
            "statusMessage": "Checking high-risk command reminder"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/post_edit_domain_router.py",
            "timeout": 10,
            "statusMessage": "Routing domain docs for edited paths"
          }
        ]
      }
    ]
  }
}
